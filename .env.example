# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Cloudflare Turnstile protects the public registration form from automated abuse.
TURNSTILE_REQUIRED="true"
TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# Supabase Credentials (Optional for preview, falls back to mock memory DB if left empty)
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# PayPal Credentials (Optional, falls back to simulated checkout if left empty)
CHECKOUT_ENABLED="false"
ALLOW_MOCK_CHECKOUT="false"
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_ENV="sandbox" # "sandbox" or "live"
