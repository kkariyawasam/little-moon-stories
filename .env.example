# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Optional: required to call protected admin-only API routes such as /api/subscribers.
ADMIN_API_KEY="CHANGE_ME_TO_A_LONG_RANDOM_SECRET"

# Supabase Credentials (Optional for preview, falls back to mock memory DB if left empty)
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# PayPal Credentials (Optional, falls back to simulated checkout if left empty)
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_ENV="sandbox" # "sandbox" or "live"
